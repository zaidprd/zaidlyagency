    klik untuk tanya-tanya via whatsapp
  </div>
</a>
  </div>
</header>

<script is:inline>
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const icon = document.getElementById('menu-icon');
  const body = document.body;

  // 1. Fungsi Utama Buka-Tutup
  function toggleMenu(forceClose = false) {
    const isOpen = menu.classList.contains('translate-x-0');
    
    // Jika sedang terbuka atau dipaksa tutup
    if (isOpen || forceClose) {
      menu.classList.add('translate-x-full', 'opacity-0');
      menu.classList.remove('translate-x-0', 'opacity-100');
      icon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7" />';
      body.style.overflow = 'auto';
      setTimeout(() => {
        if (!menu.classList.contains('translate-x-0')) menu.classList.add('invisible');
      }, 500);
    } else {
      // Buka Menu
      menu.classList.remove('invisible', 'opacity-0', 'translate-x-full');
      menu.classList.add('visible', 'opacity-100', 'translate-x-0');
      icon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />';
      body.style.overflow = 'hidden';
    }
  }

  // 2. Klik Tombol Burger
  toggle?.addEventListener('click', (e) => {
    e.stopPropagation();
    toggleMenu();
  });

  // 3. JURUS SAKTI: Klik di mana saja di luar menu untuk menutup
  document.addEventListener('click', (e) => {
    const isClickInsideMenu = menu.contains(e.target);
    const isClickOnToggle = toggle.contains(e.target);
    const isOpen = menu.classList.contains('translate-x-0');

    if (isOpen && !isClickInsideMenu && !isClickOnToggle) {
      toggleMenu(true);
    }
  });

  // 4. Klik link menu langsung tutup (Penting buat One-Page)
  const menuLinks = menu.querySelectorAll('a');
  menuLinks.forEach(link => {
    link.addEventListener('click', () => toggleMenu(true));
  });

  // 5. ESC Key buat nutup (User Laptop/Tablet)
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && menu.classList.contains('translate-x-0')) {
      toggleMenu(true);
    }
  });
</script>
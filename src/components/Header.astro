    <a href="https://wa.me/6281274203815" 
   class="w-full mt-4 bg-gradient-to-r from-[#7E67F8] to-[#6c54ec] text-white p-3 rounded-xl shadow-[0_10px_25px_rgba(126,103,248,0.3)] text-center transition-all duration-300 hover:scale-[1.03] block border border-white/10">
  

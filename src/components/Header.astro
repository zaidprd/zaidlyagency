---
// Header.astro - Optimized for Zaidly Agency
---
<header id="main-header" class="fixed top-0 left-0 w-full z-50 transition-all duration-500 py-6 bg-white/70 backdrop-blur-md border-b border-transparent">
  <div class="container mx-auto px-4">
    <div class="flex items-center justify-between">
      
      <div class="flex items-center">
        <a href="/" class="text-3xl font-bold text-slate-900 font-oswald uppercase tracking-tighter">
          Zaid<span class="text-[#7E67F8]">ly</span>
        </a>
      </div>

      <nav class="hidden lg:flex items-center space-x-12 ml-auto mr-12">
        {[
          { name: 'Home', url: '/' },
          { name: 'Kontak', url: '/contact' },
          { name: 'Blog', url: '/blog' }
        ].map((item) => (
          <a 
            href={item.url} 
            class="group relative text-[13px] font-bold text-slate-900 uppercase tracking-[0.2em] font-oswald transition-colors hover:text-[#7E67F8]"
          >
            {item.name}
            <span class="absolute -bottom-1 left-0 w-0 h-0.5 bg-[#7E67F8] transition-all duration-300 group-hover:w-full"></span>
          </a>
        ))}
      </nav>

      <div class="hidden lg:flex items-center">
        <a 
          href="https://wa.me/6281274203815?text=Halo%20Zaidly%20Agency,%20saya%20tertarik%20buat%20website" 
          target="_blank" 
          class="group relative overflow-hidden bg-[#7E67F8] text-white px-10 py-4 font-bold text-[12px] uppercase tracking-[0.2em] transition-all duration-300 font-oswald flex items-center gap-3 hover:scale-110 hover:-rotate-1 active:scale-95 shadow-[0_0_20px_rgba(126,103,248,0.4)] hover:shadow-[0_0_30px_rgba(126,103,248,0.6)] rounded-sm"
        >
          <div class="absolute inset-0 block animate-shimmer pointer-events-none">
              <div class="h-full w-1/2 bg-gradient-to-r from-transparent via-white/30 to-transparent transform -skew-x-20"></div>
          </div>
          <span class="relative z-10">Pesan Sekarang</span>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 relative z-10 group-hover:translate-x-2 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>

      <button class="lg:hidden text-slate-900 p-2 z-[60]" id="mobile-menu-toggle" aria-label="Menu">
        <svg xmlns="http://www.w3.org/2000/svg" id="menu-icon" class="h-8 w-8 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7" />
        </svg>
      </button>

    </div>
  </div>

  <div id="mobile-menu" class="fixed inset-0 bg-slate-900/95 z-50 flex flex-col items-center justify-center space-y-8 transition-all duration-500 opacity-0 invisible translate-x-full">
    {[
      { name: 'Home', url: '/' },
      { name: 'Kontak', url: '/contact' },
      { name: 'Blog', url: '/blog' }
    ].map((item) => (
      <a href={item.url} class="text-2xl font-bold text-white uppercase tracking-widest font-oswald hover:text-[#7E67F8] transition-colors mobile-link">
        {item.name}
      </a>
    ))}
    <a href="https://wa.me/6281274203815" class="mt-4 bg-[#7E67F8] text-white px-8 py-4 font-bold font-oswald uppercase tracking-wider rounded-sm">
      Pesan Sekarang
    </a>
  </div>
</header>

<script is:inline>
  const header = document.getElementById('main-header');
  const menuToggle = document.getElementById('mobile-menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');
  const menuIcon = document.getElementById('menu-icon');
  const body = document.body;

  // Toggle Menu
  menuToggle?.addEventListener('click', () => {
    const isOpen = mobileMenu.classList.contains('translate-x-0');
    
    if (!isOpen) {
      // Buka Menu
      mobileMenu.classList.remove('invisible', 'opacity-0', 'translate-x-full');
      mobileMenu.classList.add('visible', 'opacity-100', 'translate-x-0');
      menuIcon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />'; // Icon X
      body.style.overflow = 'hidden'; // Stop scroll saat menu buka
    } else {
      // Tutup Menu
      mobileMenu.classList.add('invisible', 'opacity-0', 'translate-x-full');
      mobileMenu.classList.remove('visible', 'opacity-100', 'translate-x-0');
      menuIcon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7" />'; // Icon Hamburger
      body.style.overflow = 'auto';
    }
  });

  // Close menu when clicking link
  document.querySelectorAll('.mobile-link').forEach(link => {
    link.addEventListener('click', () => {
      mobileMenu.classList.add('translate-x-full', 'opacity-0');
      body.style.overflow = 'auto';
    });
  });

  // Scroll effect
  window.addEventListener('scroll', () => {
    if (header) { 
      if (window.scrollY > 20) {
        header.classList.add('py-4', 'bg-white/90', 'shadow-sm');
        header.classList.remove('py-6', 'bg-white/70');
      } else {
        header.classList.add('py-6', 'bg-white/70');
        header.classList.remove('py-4', 'bg-white/90', 'shadow-sm');
      }
    }
  });
</script>

<style>
  @keyframes shimmer {
    0% { transform: translateX(-150%); }
    100% { transform: translateX(150%); }
  }
  .animate-shimmer {
    animation: shimmer 3s infinite ease-in-out;
  }
</style>

---
// Header.astro - Minimalist White Mobile Menu Style for Zaidly Agency
---
<header id="main-header" class="fixed top-0 left-0 w-full z-50 transition-all duration-500 py-6 bg-white/70 backdrop-blur-md border-b border-transparent">
  <div class="container mx-auto px-4">
    <div class="flex items-center justify-between">
      
      <div class="flex items-center z-[60]"> <a href="/" class="text-3xl font-bold text-slate-900 font-oswald uppercase tracking-tighter">
          Zaid<span class="text-[#7E67F8]">ly</span>
        </a>
      </div>

      <nav class="hidden lg:flex items-center space-x-12 ml-auto mr-12">
        {[
          { name: 'Home', url: '/' },
          { name: 'Kontak', url: '/contact' },
          { name: 'Blog', url: '/blog' }
        ].map((item) => (
          <a 
            href={item.url} 
            class="group relative text-[13px] font-bold text-slate-900 uppercase tracking-[0.2em] font-oswald transition-colors hover:text-[#7E67F8]"
          >
            {item.name}
            <span class="absolute -bottom-1 left-0 w-0 h-0.5 bg-[#7E67F8] transition-all duration-300 group-hover:w-full"></span>
          </a>
        ))}
      </nav>

      <div class="hidden lg:flex items-center">
        <a 
          href="https://wa.me/6281274203815" 
          target="_blank" 
          class="group relative overflow-hidden bg-[#7E67F8] text-white px-10 py-4 font-bold text-[12px] uppercase tracking-[0.2em] transition-all duration-300 font-oswald flex items-center gap-3 rounded-sm shadow-[0_0_20px_rgba(126,103,248,0.4)]"
        >
          Pesan Sekarang
        </a>
      </div>

      <button class="lg:hidden text-slate-900 p-2 z-[60]" id="mobile-menu-toggle" aria-label="Menu">
        <svg xmlns="http://www.w3.org/2000/svg" id="menu-icon" class="h-8 w-8 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7" />
        </svg>
      </button>

    </div>
  </div>

  <div id="mobile-menu" class="fixed top-0 right-0 w-[80%] h-[70vh] bg-white backdrop-blur-sm z-50 flex flex-col items-center justify-center space-y-10 transition-transform duration-500 ease-in-out translate-x-full rounded-l-2xl shadow-2xl invisible opacity-0 border-l border-slate-100">
    {[
      { name: 'Home', url: '/' },
      { name: 'Kontak', url: '/contact' },
      { name: 'Blog', url: '/blog' }
    ].map((item) => (
      <a href={item.url} class="text-3xl font-bold text-slate-900 uppercase tracking-widest font-oswald hover:text-[#7E67F8] transition-colors mobile-link">
        {item.name}
      </a>
    ))}
    <a href="https://wa.me/6281274203815" class="mt-4 bg-[#7E67F8] text-white px-8 py-4 font-bold font-oswald uppercase tracking-wider rounded-sm text-sm hover:scale-105 transition-transform shadow-[0_0_15px_rgba(126,103,248,0.3)]">
      Pesan Sekarang
    </a>
  </div>
</header>

<script is:inline>
  const header = document.getElementById('main-header');
  const menuToggle = document.getElementById('mobile-menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');
  const menuIcon = document.getElementById('menu-icon');
  const body = document.body;

  // Toggle Menu
  menuToggle?.addEventListener('click', () => {
    const isOpen = mobileMenu.classList.contains('translate-x-0');
    
    if (!isOpen) {
      // Buka Menu (Background PUTIH)
      mobileMenu.classList.remove('invisible', 'opacity-0', 'translate-x-full');
      mobileMenu.classList.add('visible', 'opacity-100', 'translate-x-0');
      menuIcon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />'; // Icon X
      body.style.overflow = 'hidden'; // Stop scroll saat menu buka
    } else {
      // Tutup Menu
      mobileMenu.classList.add('translate-x-full', 'opacity-0');
      mobileMenu.classList.remove('translate-x-0', 'opacity-100');
      menuIcon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7" />'; // Icon Hamburger
      body.style.overflow = 'auto';
      // Tambahkan delay sedikit sebelum set invisible agar animasi transisi keluar kelihatan
      setTimeout(() => {
        if (!mobileMenu.classList.contains('translate-x-0')) {
          mobileMenu.classList.add('invisible');
        }
      }, 500);
    }
  });

  // Close menu when clicking link
  document.querySelectorAll('.mobile-link').forEach(link => {
    link.addEventListener('click', () => {
      mobileMenu.classList.add('translate-x-full', 'opacity-0');
      mobileMenu.classList.remove('translate-x-0', 'opacity-100');
      menuIcon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7" />';
      body.style.overflow = 'auto';
    });
  });

  // Scroll effect (Jangan ubah padding header kalau menu lagi buka)
  window.addEventListener('scroll', () => {
    if (header && !mobileMenu.classList.contains('translate-x-0')) { 
      if (window.scrollY > 20) {
        header.classList.add('py-4', 'bg-white/95', 'shadow-sm');
        header.classList.remove('py-6', 'bg-white/70');
      } else {
        header.classList.add('py-6', 'bg-white/70');
        header.classList.remove('py-4', 'bg-white/95', 'shadow-sm');
      }
    }
  });
</script>

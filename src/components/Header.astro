---
// Header.astro - FINAL STABLE
---

<header id="main-header" class="fixed top-0 left-0 w-full z-[100] transition-all duration-500 py-6 bg-white/70 backdrop-blur-md border-b border-transparent">
  <div class="container mx-auto px-4">
    <div class="flex items-center justify-between">

      <div class="flex items-center">
        <a href="/" class="text-3xl font-bold text-slate-900 font-oswald uppercase tracking-tighter hover:scale-105 transition-transform">
          Zaid<span class="text-[#7E67F8]">ly</span>
        </a>
      </div>

      <nav class="hidden lg:flex items-center space-x-12 ml-auto mr-12">
        <a href="/" class="text-[13px] font-bold text-slate-900 uppercase font-oswald hover:text-[#7E67F8]">HOME</a>
        <a href="/contact" class="text-[13px] font-bold text-slate-900 uppercase font-oswald hover:text-[#7E67F8]">KONTAK</a>
        <a href="/blog" class="text-[13px] font-bold text-slate-900 uppercase font-oswald hover:text-[#7E67F8]">BLOG</a>
      </nav>

      <div class="hidden lg:block">
        <a href="https://wa.me/6281274203815" target="_blank"
          class="bg-[#7E67F8] text-white px-8 py-3 font-bold text-[12px] uppercase tracking-wider transition-all duration-300 font-oswald rounded-sm shadow-[0_0_20px_rgba(126,103,248,0.3)] hover:scale-105 inline-block">
          Pesan Sekarang
        </a>
      </div>

      <!-- ✅ touch-action: manipulation → hapus 300ms delay tanpa double-fire -->
      <button
        id="mobile-menu-toggle"
        class="lg:hidden text-slate-900 p-2 z-[130] relative"
        style="touch-action: manipulation;"
        aria-label="Buka Menu Navigasi"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg xmlns="http://www.w3.org/2000/svg"
          class="h-8 w-8 pointer-events-none transition-all duration-300"
          fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path id="icon-path" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7"/>
        </svg>
      </button>

    </div>
  </div>

  <div id="mobile-menu" class="fixed top-0 right-0 w-[75%] max-w-sm h-screen z-[120] flex flex-col items-start p-10 pt-32 space-y-10 bg-white/90 backdrop-blur-xl border-l border-white/40 shadow-2xl rounded-l-3xl">
    <a href="/" class="text-xl font-bold text-slate-900 font-oswald uppercase hover:text-[#7E67F8]">HOME</a>
    <a href="/contact" class="text-xl font-bold text-slate-900 font-oswald uppercase hover:text-[#7E67F8]">KONTAK</a>
    <a href="/blog" class="text-xl font-bold text-slate-900 font-oswald uppercase hover:text-[#7E67F8]">BLOG</a>
    <a href="https://wa.me/6281274203815"
      class="w-full mt-4 bg-gradient-to-r from-[#7E67F8] to-[#6c54ec] text-white p-3 rounded-xl text-center shadow-lg hover:scale-[1.03] transition-all">
      <div class="font-bold uppercase text-sm">PESAN SEKARANG</div>
      <div class="text-[10px] opacity-80 italic">klik untuk tanya via WhatsApp</div>
    </a>
  </div>
</header>

<style>
  #mobile-menu {
    transform: translateX(100%);
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: all 0.35s ease;
  }
  #mobile-menu.open {
    transform: translateX(0);
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
  }
</style>

<script is:inline>
  if (!window.__menuInitialized) {
    window.__menuInitialized = true;

    const toggle = document.getElementById('mobile-menu-toggle');
    const menu = document.getElementById('mobile-menu');
    const iconPath = document.getElementById('icon-path');
    const body = document.body;

    const ICON_BURGER = 'M4 6h16M4 12h16m-7 6h7';
    const ICON_CLOSE  = 'M6 18L18 6M6 6l12 12';
    let isOpen = false;

    function openMenu() {
      isOpen = true;
      menu.classList.add('open');
      iconPath.setAttribute('d', ICON_CLOSE);
      toggle.setAttribute('aria-expanded', 'true');
      body.style.overflow = 'hidden';
    }

    function closeMenu() {
      isOpen = false;
      menu.classList.remove('open');
      iconPath.setAttribute('d', ICON_BURGER);
      toggle.setAttribute('aria-expanded', 'false');
      body.style.overflow = ''; // ✅ reset ke default, bukan 'auto'
    }

    // ✅ Hanya 'click' — touchstart dihapus untuk cegah double-fire
    toggle.addEventListener('click', (e) => {
      e.stopPropagation();
      isOpen ? closeMenu() : openMenu();
    });

    document.addEventListener('click', (e) => {
      if (isOpen && !menu.contains(e.target) && !toggle.contains(e.target)) {
        closeMenu();
      }
    });

    menu.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', closeMenu);
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && isOpen) closeMenu();
    });
  }
</script>

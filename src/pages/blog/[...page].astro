---
import Layout from '../../layouts/Layout.astro';
import { client, urlFor } from '../../lib/sanity';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths = (async ({ paginate }) => {
  const allPosts = await client.fetch(`*[_type == "post"] | order(publishedAt desc) {
    title,
    "slug": slug.current,
    mainImage,
    publishedAt,
    excerpt,
    "authorName": author->name,
    "categories": categories[]->title
  }`);

  return paginate(allPosts, { pageSize: 10 });
}) satisfies GetStaticPaths;

const { page } = Astro.props;
---

<Layout 
  title={`Blog Zaidly Agency - Halaman ${page.currentPage}`} 
  description="Daftar artikel Zaidly Agency tampilan full width vertikal."
>
  
  <section class="pt-40 pb-20 bg-slate-50 border-b border-slate-100 text-center">
    <div class="container mx-auto px-4">
       <span class="text-[#7E67F8] font-oswald uppercase font-bold text-[12px] tracking-[0.3em] mb-4 block">Our Insights</span>
       <h1 class="text-6xl md:text-8xl font-bold font-oswald uppercase text-slate-900 tracking-tighter">
         Blog
       </h1>
    </div>
  </section>

  <main class="py-24 bg-white">
    <div class="container mx-auto px-4 max-w-4xl space-y-32">
      
      {page.data.map((post: any) => (
        <article class="relative flex flex-col w-full">
          
          <div class="relative w-full shadow-2xl bg-slate-900 aspect-video rounded-sm">
            <a href={`/${post.slug}`} class="block w-full h-full p-2">
              <img 
                src={urlFor(post.mainImage).width(1200).url()} 
                alt={post.mainImage.alt || post.title} 
                class="w-full h-full object-contain transition-transform duration-700 hover:scale-105"
              />
            </a>

            <div class="absolute -bottom-8 left-0 md:left-10 bg-[#1A1A1A] text-white flex items-center gap-6 px-8 py-5 text-[11px] font-oswald uppercase tracking-[0.2em] z-50 shadow-2xl border-l-4 border-[#7E67F8]">
                <div class="flex items-center gap-2">
                  <span class="text-[#7E67F8]">📅</span>
                  {new Date(post.publishedAt).toLocaleDateString('id-ID', { day: 'numeric', month: 'long', year: 'numeric' })}
                </div>
                <div class="w-px h-4 bg-slate-700"></div>
                <div class="flex items-center gap-2">
                  <span class="text-[#7E67F8]">👤</span>
                  BY - {post.authorName || 'ZAID'}
                </div>
            </div>
          </div>

          <div class="mt-20 space-y-6">
            <div class="flex gap-2">
              {post.categories?.map((cat: string) => (
                <span class="text-[#7E67F8] text-[11px] font-bold uppercase tracking-[0.2em]">{cat}</span>
              ))}
            </div>
            
            <a href={`/${post.slug}`} class="block">
              <h2 class="text-4xl md:text-6xl font-bold font-oswald uppercase leading-tight text-slate-900 hover:text-[#7E67F8] transition-colors tracking-tighter">
                {post.title}
              </h2>
            </a>

            <p class="text-slate-500 font-mulish text-base leading-relaxed line-clamp-3 max-w-3xl">
              {post.excerpt}
            </p>

            <div class="pt-6">
              <a href={`/${post.slug}`} class="inline-flex items-center gap-4 text-[#7E67F8] font-oswald font-bold text-xs uppercase tracking-[0.3em] group">
                Read Full Article 
                <span class="w-10 h-px bg-[#7E67F8] transition-all duration-300 group-hover:w-16"></span>
              </a>
            </div>
          </div>

        </article>
      ))}

      {page.lastPage > 1 && (
        <div class="mt-40 flex justify-center items-center gap-4 border-t pt-20 border-slate-100">
           {page.url.prev && (
             <a href={page.url.prev} class="px-8 py-4 bg-slate-900 text-white font-oswald font-bold text-xs uppercase tracking-widest hover:bg-[#7E67F8] transition-all">PREV</a>
           )}
           <span class="font-oswald font-bold text-slate-900 px-6 py-4 bg-slate-50 text-xs border border-slate-200">{page.currentPage} / {page.lastPage}</span>
           {page.url.next && (
             <a href={page.url.next} class="px-8 py-4 bg-slate-900 text-white font-oswald font-bold text-xs uppercase tracking-widest hover:bg-[#7E67F8] transition-all">NEXT</a>
           )}
        </div>
      )}

    </div>
  </main>
</Layout>
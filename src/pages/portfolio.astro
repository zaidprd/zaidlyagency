---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';

// Import foto dari assets
import port1 from '../assets/portfolio-1.webp';
import port2 from '../assets/portfolio-2.webp'; 
import port3 from '../assets/portfolio-3.webp';
import port4 from '../assets/portfolio-4.webp';
import port5 from '../assets/portfolio-5.webp';
import port6 from '../assets/portfolio-6.webp';

const projects = [
  { title: "Panel Maker Type Test", category: "Company Profile", image: port1, link: "https://bloksetschneider.com/" },
  { title: "Konsultan Bisnis", category: "Company Profile", image: port2, link: "https://jayakonsultanbisnis.com/" },
  { title: "Sales Panel", category: "Marketing", image: port3, link: "https://yudisimetri.pages.dev/" },
  { title: "Logistik", category: "Company Profile", image: port4, link: "https://deltalogistik.id/" },
  { title: "Affiliate Marketing", category: "Affiliate", image: port5, link: "https://zaidly.pages.dev" },
  { title: "Sertifikasi ISO", category: "Company Profile", image: port6, link: "https://induscipta.com/" }
];
---

<Layout title="Portofolio Proyek Terkini | Zaidly Agency">
  <main class="pt-32 pb-20 bg-[#F8F9FA]">
    
    <section class="container mx-auto px-4 mb-16 text-center">
      <span class="text-[#6c54ec] font-bold tracking-widest uppercase mb-4 block text-sm">
        Our Work & Projects
      </span>
      <h1 class="text-4xl md:text-6xl font-bold text-slate-900 font-oswald uppercase tracking-tighter">
        Portofolio <span class="italic text-[#7E67F8]">Terbaru</span>
      </h1>
      <p class="mt-4 text-slate-600 max-w-2xl mx-auto font-mulish">
        Kumpulan hasil karya digital terbaik kami dalam membantu UMKM dan bisnis go-online dengan website profesional.
      </p>
    </section>

    <section class="container mx-auto px-4">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {projects.map((item) => (
          <a 
            href={item.link} 
            target="_blank" 
            rel="noopener noreferrer" 
            aria-label={`Lihat detail proyek ${item.title}`}
            class="group relative block bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-2xl transition-all duration-500 hover:-translate-y-2"
          >
            
            <div class="relative h-280px overflow-hidden bg-slate-200">
              <Image 
                src={item.image} 
                alt={`Tampilan website portofolio ${item.title} oleh Zaidly Agency`}
                class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
              />
              <div class="absolute inset-0 bg-[#7E67F8]/80 opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex items-center justify-center">
                <span class="text-white font-bold font-oswald uppercase tracking-widest border-2 border-white px-6 py-2">
                  View Project
                </span>
              </div>
            </div>

            <div class="p-6">
              <span class="text-[10px] font-bold text-[#6c54ec] uppercase tracking-[3px] mb-2 block">
                {item.category}
              </span>
              <h2 class="text-xl font-bold text-slate-900 font-oswald uppercase transition-colors group-hover:text-[#7E67F8]">
                {item.title}
              </h2>
            </div>
          </a>
        ))}
      </div>
    </section>

  </main>
</Layout>